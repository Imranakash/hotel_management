<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hotel_booking_form_inherit_discount" model="ir.ui.view">
            <field name="name">hotel.booking.form.inherit.discount</field>
            <field name="model">hotel.booking</field>
            <field name="inherit_id" ref="hotel_management_core.view_hotel_booking_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='discount_amount']" position="before">
                    <field name="is_complimentary" widget="boolean_toggle"/>
                    <field name="complimentary_reason" invisible="not is_complimentary" required="is_complimentary"/>
                    <field name="promo_id" invisible="is_complimentary"/>
                    <field name="manual_discount_type" invisible="is_complimentary or promo_id != False"/>
                    <field name="manual_discount_value" invisible="is_complimentary or manual_discount_type == 'none'"/>
                </xpath>

                <xpath expr="//field[@name='discount_amount']" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>