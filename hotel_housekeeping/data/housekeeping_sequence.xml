<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Housekeeping Task Sequence -->
        <record id="seq_hotel_housekeeping_task" model="ir.sequence">
            <field name="name">Hotel Housekeeping Task Sequence</field>
            <field name="code">hotel.housekeeping.task</field>
            <field name="prefix">HKT/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Lost and Found Sequence -->
        <record id="seq_hotel_lost_found" model="ir.sequence">
            <field name="name">Hotel Lost and Found Sequence</field>
            <field name="code">hotel.lost.found</field>
            <field name="prefix">LNF/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>