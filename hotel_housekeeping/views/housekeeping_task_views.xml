<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="view_hotel_housekeeping_task_tree" model="ir.ui.view">
            <field name="name">hotel.housekeeping.task.list</field>
            <field name="model">hotel.housekeeping.task</field>
            <field name="arch" type="xml">
                <list string="Housekeeping Tasks">
                    <field name="task_no"/>
                    <field name="room_id"/>
                    <field name="task_type"/>
                    <field name="assigned_to"/>
                    <field name="priority" widget="priority"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_hotel_housekeeping_task_form" model="ir.ui.view">
            <field name="name">hotel.housekeeping.task.form</field>
            <field name="model">hotel.housekeeping.task</field>
            <field name="arch" type="xml">
                <form string="Housekeeping Task">
                    <header>
                        <button name="action_start_task" string="Start Work" type="object" class="oe_highlight"
                                invisible="state not in ['draft', 'assigned', 'rework']"/>
                        <button name="action_complete_task" string="Mark Done" type="object" class="oe_highlight"
                                invisible="state != 'in_progress'"/>
                        <button name="action_approve_task" string="Approve Inspection" type="object" class="btn-success"
                                groups="hotel_housekeeping.group_housekeeping_manager"
                                invisible="state != 'done'"/>
                        <button name="action_rework_task" string="Send for Rework" type="object" class="btn-danger"
                                groups="hotel_housekeeping.group_housekeeping_manager"
                                invisible="state != 'done'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="task_no"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="room_id"/>
                                <field name="task_type"/>
                                <field name="priority" widget="priority"/>
                                <field name="checklist_id"/>
                            </group>
                            <group>
                                <field name="assigned_to"/>
                                <field name="planned_start"/>
                                <field name="planned_end"/>
                                <field name="photo_proof" widget="image" class="oe_avatar"
                                       required="state == 'in_progress'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Checklist Items" name="checklist">
                                <field name="task_line_ids">
                                    <list editable="bottom" create="0">
                                        <field name="name" string="Item"/>
                                        <field name="is_mandatory" readonly="1" force_save="1"/>
                                        <field name="is_completed"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Execution Logs" name="logs">
                                <group>
                                    <field name="actual_start"/>
                                    <field name="actual_end"/>
                                </group>
                                <field name="note" placeholder="Add observations here..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_hotel_housekeeping_task_kanban" model="ir.ui.view">
            <field name="name">hotel.housekeeping.task.kanban</field>
            <field name="model">hotel.housekeeping.task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" quick_create="false">
                    <field name="priority"/>
                    <field name="task_no"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click card p-2 shadow-sm">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="task_no"/>
                                    </strong>
                                    <div>Room:
                                        <field name="room_id"/>
                                    </div>
                                    <div>Type:
                                        <field name="task_type"/>
                                    </div>
                                    <div>Staff:
                                        <field name="assigned_to"/>
                                    </div>
                                    <div class="o_kanban_record_bottom mt-2">
                                        <div class="oe_kanban_bottom_left">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_hotel_housekeeping_task" model="ir.actions.act_window">
            <field name="name">Housekeeping Tasks</field>
            <field name="res_model">hotel.housekeeping.task</field>
            <field name="view_mode">list,form,kanban</field>
        </record>
    </data>
</odoo>