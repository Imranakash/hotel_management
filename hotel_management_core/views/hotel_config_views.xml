<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_building_form" model="ir.ui.view">
        <field name="name">hotel.building.form</field>
        <field name="model">hotel.building</field>
        <field name="arch" type="xml">
            <form string="Building">
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. Tower A, North Wing"/>
                        <field name="property_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hotel_room_type_form" model="ir.ui.view">
        <field name="name">hotel.room.type.form</field>
        <field name="model">hotel.room.type</field>
        <field name="arch" type="xml">
            <form string="Room Category">
                <sheet>
                    <!-- প্রধান তথ্য -->
                    <div class="oe_title">
                        <label for="name" string="Room Type Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Deluxe Couple Room, Suite"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="code" placeholder="e.g. DLX, SUT, STD"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Capacity &amp; Policies" name="capacity_policies">
                            <group>
                                <group string="Capacity Setup">
                                    <field name="base_adults"/>
                                    <field name="base_children"/>
                                    <field name="max_capacity"/>
                                </group>
                                <group string="Extra Bed Policy">
                                    <field name="allow_extra_bed" widget="boolean_toggle"/>
                                    <field name="max_extra_beds" invisible="not allow_extra_bed"/>
                                </group>
                            </group>
                        </page>

                        <page string="Specifications &amp; Amenities" name="specifications_amenities">
                            <group>
                                <group string="ROOM SPECIFICATIONS">
                                    <field name="bed_type"/>
                                    <field name="view_type"/>
                                    <field name="room_area"/>
                                </group>

                                <!-- ডানপাশে: এমেনিটিজ ট্যাগস -->
                                <group string="ROOM AMENITIES">
                                    <field name="amenity_ids"
                                           widget="many2many_tags"
                                           options="{'color_field': 'color', 'no_create_edit': True}"
                                           placeholder="Select amenities (e.g. Slippers, Room Service, Toiletries)..."/>
                                </group>
                            </group>

                            <group string="Description / Features">
                                <field name="description" nolabel="1" placeholder="Write room description here..."/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hotel_building_list" model="ir.ui.view">
        <field name="name">hotel.building.list</field>
        <field name="model">hotel.building</field>
        <field name="arch" type="xml">
            <list string="Buildings">
                <field name="name"/>
                <field name="property_id"/>
            </list>
        </field>
    </record>

    <record id="view_hotel_floor_form" model="ir.ui.view">
        <field name="name">hotel.floor.form</field>
        <field name="model">hotel.floor</field>
        <field name="arch" type="xml">
            <form string="Floor">
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. 1st Floor, Ground Floor"/>
                        <field name="building_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hotel_floor_list" model="ir.ui.view">
        <field name="name">hotel.floor.list</field>
        <field name="model">hotel.floor</field>
        <field name="arch" type="xml">
            <list string="Floors">
                <field name="name"/>
                <field name="building_id"/>
            </list>
        </field>
    </record>
</odoo>