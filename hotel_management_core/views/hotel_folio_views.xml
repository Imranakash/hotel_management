<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_folio_form" model="ir.ui.view">
        <field name="name">hotel.folio.form</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <form string="Hotel Folio">
                <header>
                    <button name="action_create_invoice"
                            string="Create Invoice"
                            type="object"
                            class="btn-primary"
                            invisible="invoice_count > 0"/>

                    <button name="action_print_invoice"
                            string="Print Invoice"
                            type="object"
                            class="btn-secondary"
                            invisible="invoice_count == 0"
                            icon="fa-print"/>


                    <field name="state" widget="statusbar" statusbar_visible="open,billed,paid"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_booking"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calendar"
                                invisible="booking_count == 0">
                            <field name="booking_count" widget="statinfo" string="Booking"/>
                        </button>

                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1 class="d-flex flex-row align-items-center">
                            <field name="folio_no"
                                   placeholder="Folio Number"
                                   readonly="1"
                                   invisible="folio_no == 'New'"/>
                            <span class="text-muted font-weight-normal" invisible="folio_no != 'New'">
                                New Folio
                            </span>
                        </h1>
                    </div>

                    <group>
                        <group string="Stay Info">
                            <field name="booking_id" string="Guest / Booking Ref" options="{'no_create': True}"/>
                            <field name="guest_id" readonly="1" force_save="1"/>
                            <field name="room_id" readonly="1" force_save="1"/>
                        </group>
                        <group string="Financials">
                            <field name="amount_net_total" widget="monetary" string="Net Total Amount" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Folio Charges / Bill Lines" name="folio_lines">
                            <field name="folio_line_ids">
                                <list string="Folio Lines" editable="bottom">
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" widget="monetary" sum="Total Subtotal"/>
                                    <field name="source_reference" readonly="1" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hotel_folio_list" model="ir.ui.view">
        <field name="name">hotel.folio.list</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <list string="Hotel Folios" decoration-success="state == 'paid'" decoration-info="state == 'open'"
                  decoration-warning="state == 'billed'">
                <field name="folio_no"/>
                <field name="guest_id"/>
                <field name="room_id" optional="show"/>
                <field name="amount_net_total" widget="monetary" sum="Grand Total Billing"/>
                <field name="state" widget="badge" decoration-success="state == 'paid'"
                       decoration-info="state == 'open'"
                       decoration-warning="state == 'billed'"/>
            </list>
        </field>
    </record>


    <record id="view_hotel_folio_kanban" model="ir.ui.view">
        <field name="name">hotel.folio.kanban</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1" records_draggable="false">
                <field name="id"/>
                <field name="folio_no"/>
                <field name="guest_id"/>
                <field name="room_id"/>
                <field name="amount_net_total"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-3 d-flex flex-column justify-content-between row-gap-2">
                            <div>

                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="fs-5 text-dark">📜 <field name="folio_no"/></strong>
                                    <span class="badge bg-secondary p-1">🚪 <field name="room_id"/></span>
                                </div>

                                <div class="text-muted small">
                                    👤 <field name="guest_id"/>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center border-top pt-2 mt-2">
                                <span class="text-muted small">Net Bill:</span>
                                <strong class="text-primary fs-6">
                                    <field name="amount_net_total" widget="monetary"/>
                                </strong>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_hotel_folio" model="ir.actions.act_window">
        <field name="name">Hotel Folios</field>
        <field name="res_model">hotel.folio</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>