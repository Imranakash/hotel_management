<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_booking_approval_wizard_form" model="ir.ui.view">
        <field name="name">hotel.booking.approval.wizard.form</field>
        <field name="model">hotel.booking.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Manager Approval Desk">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>Attention Manager!</strong> Action required for this booking discount/credit configuration.
                    </div>
                    <group>
                        <group>
                            <field name="approval_state" widget="badge"
                                   decoration-warning="approval_state in ['waiting', 'not_required', 'no_needed']"
                                   decoration-success="approval_state == 'approved'"
                                   decoration-danger="approval_state == 'rejected'"/>
                            <field name="is_credit_exceeded" readonly="1"/>
                        </group>
                        <group>
                            <field name="approval_reason" required="1" placeholder="Please enter the logical reason for approval or rejection here..."/>
                        </group>
                    </group>
                </sheet>

                <footer>
                    <button name="button_approve" string="✔ Approve &amp; Confirm" type="object" class="btn-success"/>
                    <button name="button_reject" string="❌ Reject &amp; Cancel" type="object" class="btn-danger"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>