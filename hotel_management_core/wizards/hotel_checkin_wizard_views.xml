<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_checkin_wizard_form" model="ir.ui.view">
        <field name="name">hotel.checkin.wizard.form</field>
        <field name="model">hotel.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Available Rooms for Check-In">
                <sheet>
                    <field name="booking_id" invisible="1"/>
                    <field name="property_id" invisible="1"/>
                    <group>
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" create="false" delete="false">
                                <field name="room_type_id" readonly="1"/>
                                <field name="room_id" options="{'no_create': True, 'no_open': True}" context="{'show_custom_display_name': True}"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm Check-In" name="action_assign_rooms_and_confirm_checkin" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>