<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Loyalty History List View -->
    <record id="view_hotel_loyalty_history_list" model="ir.ui.view">
        <field name="name">hotel.loyalty.history.list</field>
        <field name="model">hotel.loyalty.history</field>
        <field name="arch" type="xml">
            <list string="Loyalty Ledgers &amp; Redemption" editable="top">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="transaction_type"/>
                <field name="redemption_type"/>
                <field name="free_nights_count" invisible="redemption_type != 'free_night'"/>
                <field name="points"/>
                <field name="source_document"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hotel_loyalty_history" model="ir.actions.act_window">
        <field name="name">Points &amp; Redemptions</field>
        <field name="res_model">hotel.loyalty.history</field>
        <field name="view_mode">list</field>
    </record>
</odoo>