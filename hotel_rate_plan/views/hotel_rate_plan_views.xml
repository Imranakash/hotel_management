<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hotel_rate_plan_tree" model="ir.ui.view">
            <field name="name">hotel.rate.plan.list</field>
            <field name="model">hotel.rate.plan</field>
            <field name="arch" type="xml">
                <list string="Rate Plans">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="market_segment" />
                    <field name="priority"/>
                    <field name="valid_from"/>
                    <field name="valid_to"/>
                </list>
            </field>
        </record>

        <record id="view_hotel_rate_plan_form" model="ir.ui.view">
            <field name="name">hotel.rate.plan.form</field>
            <field name="model">hotel.rate.plan</field>
            <field name="arch" type="xml">
                <form string="Rate Plan">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Peak Season Standard Rate"/></h1>
                        </div>
                        <group>
                            <group string="Identity &amp; Priority">
                                <field name="code"/>
                                <field name="priority"/>
                                <field name="market_segment"/>
                            </group>
                            <group string="Validity &amp; Inclusions">
                                <field name="valid_from"/>
                                <field name="valid_to"/>
                                <field name="tax_included"/>
                                <field name="service_charge_included"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Pricing Lines / Rules" name="rate_lines">
                                <field name="rate_line_ids">
                                    <list editable="bottom">
                                        <field name="room_id"/>
                                        <field name="date_from"/>
                                        <field name="date_to"/>
                                        <field name="base_rate"/>
                                        <field name="weekend_rate"/>
                                        <field name="extra_adult_charge"/>
                                        <field name="extra_child_charge"/>
                                        <field name="extra_bed_charge"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_hotel_package_tree" model="ir.ui.view">
            <field name="name">hotel.package.list</field>
            <field name="model">hotel.package</field>
            <field name="arch" type="xml">
                <list string="Packages">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="price_mode"/>
                    <field name="fixed_package_price"/>
                    <field name="valid_from"/>
                    <field name="valid_to"/>
                </list>
            </field>
        </record>

        <record id="view_hotel_package_form" model="ir.ui.view">
            <field name="name">hotel.package.form</field>
            <field name="model">hotel.package</field>
            <field name="arch" type="xml">
                <form string="Package">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="price_mode"/>
                            <field name="fixed_package_price" invisible="price_mode != 'fixed'"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                        </group>
                        <group string="Package Inclusions">
                            <field name="inclusion_notes" placeholder="Write down free bundled items..."/>
                        </group>
                    </sheet>
                    <chatter>
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </chatter>
                </form>
            </field>
        </record>

        <record id="action_hotel_rate_plan" model="ir.actions.act_window">
            <field name="name">Rate Plans</field>
            <field name="res_model">hotel.rate.plan</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_hotel_package" model="ir.actions.act_window">
            <field name="name">Bundled Packages</field>
            <field name="res_model">hotel.package</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_hotel_booking_form_inherit_package" model="ir.ui.view">
            <field name="name">hotel.booking.form.inherit.package</field>
            <field name="model">hotel.booking</field>
            <field name="inherit_id" ref="hotel_management_core.view_hotel_booking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='deposit_amount']" position="after">
                    <field name="package_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="fixed_package_price" force_save="1"/>
                </xpath>
            </field>
        </record>

        <menuitem id="menu_hotel_pricing_root_independent"
                  name="Pricing &amp; Rates"
                  sequence="25"/>

        <menuitem id="menu_hotel_rate_plan_sub"
                  name="Rate Plans"
                  parent="hotel_management_core.menu_hotel_configuration"
                  action="action_hotel_rate_plan"
                  sequence="35"/>

        <menuitem id="menu_hotel_package_sub"
                  name="Packages Setup"
                  parent="hotel_management_core.menu_hotel_configuration"
                  action="action_hotel_package"
                  sequence="40"/>
    </data>
</odoo>